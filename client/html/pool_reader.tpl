<div class='reader'>
    <div class='reader-topbar'>
        <a class='reader-back' href='<%- ctx.poolUrl %>' title='Back to pool'>&#8592;</a>
        <span class='reader-title'><%- ctx.pool.names[0] %></span>
        <span class='reader-counter'></span>
        <span class='reader-controls'>
            <a href class='reader-fit button'>Fit: both</a>
            <a href class='reader-mode button'>Continuous</a>
            <a href class='reader-fullscreen button'>Fullscreen</a>
        </span>
    </div>
    <div class='reader-body'></div>
</div>
