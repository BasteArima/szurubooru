@import colors

#auto-tag
    width: 64em
    max-width: 100%
    text-align: left

    // core-forms.styl sets `form { width: 20em }`; let ours use the full width
    form
        width: 100%
        max-width: 100%

    h1
        margin-bottom: 0.4em
    h2
        margin: 0 0 0.6em 0

    .settings-grid
        display: grid
        grid-template-columns: repeat(auto-fit, minmax(22em, 1fr))
        gap: 1em
        align-items: start

    fieldset
        margin: 0
        border: 1px solid rgba(127, 127, 127, 0.35)
        border-radius: 5px
        padding: 0.7em 1em 1em

        &.wide
            grid-column: 1 / -1

        legend
            padding: 0 0.4em
            font-weight: bold

        .hint
            font-weight: normal
            opacity: 0.55
            font-size: 0.85em

    .checks
        display: flex
        flex-wrap: wrap
        gap: 0.4em 1.2em
        margin: 0.2em 0 0.7em

    label.inline
        display: inline-flex
        align-items: center
        gap: 0.4em
        margin: 0
        white-space: nowrap

        input
            margin: 0

    label.field
        display: flex
        align-items: center
        gap: 0.7em
        margin: 0.45em 0

        >span
            flex: 0 0 8.5em
            opacity: 0.8
            text-align: right

        input
            flex: 1 1 auto
            min-width: 0
            margin: 0

        &.small >span
            flex: 0 0 auto
            text-align: left

    .sources
        margin-top: 0.7em

        .sub
            display: block
            opacity: 0.7
            margin-bottom: 0.4em

        .source-cards
            display: grid
            grid-template-columns: repeat(auto-fit, minmax(15em, 1fr))
            gap: 0.7em

        .source
            border: 1px solid rgba(127, 127, 127, 0.3)
            border-radius: 4px
            padding: 0.5em 0.7em

            >label.inline
                font-weight: bold
                margin-bottom: 0.35em

            label.field
                margin: 0.3em 0
                gap: 0.4em
                >span
                    flex: 0 0 4.5em
                    text-align: left

    .sources-hint
        margin: 0.5em 0 0
        font-size: 0.85em
        opacity: 0.6

    .category-map
        margin-top: 0.9em

        .sub
            display: block
            opacity: 0.7
            margin-bottom: 0.3em

        .map-grid
            display: grid
            grid-template-columns: repeat(auto-fit, minmax(9em, 1fr))
            gap: 0.3em 0.8em

            label.field
                margin: 0
                gap: 0.35em

    input[type=submit]
        margin-top: 1.2em

    .auto-tag-run
        .row
            display: flex
            align-items: center
            flex-wrap: wrap
            gap: 0.4em 1em
            margin: 0.5em 0

            >.label
                flex: 0 0 5.5em
                opacity: 0.75

            input[type=text]
                flex: 1 1 20em
                min-width: 0

        .start
            margin-top: 0.8em

    .job-status
        margin-top: 1.2em
        padding: 0.8em 1em
        border: 1px solid rgba(127, 127, 127, 0.35)
        border-radius: 5px

        &:empty
            display: none

        .info
            font-weight: bold
        .counts
            opacity: 0.8
            margin-top: 0.2em
        .msg
            margin-top: 0.3em
            color: tomato
        .controls
            margin-top: 0.7em
            button
                margin-right: 0.5em
