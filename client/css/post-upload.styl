@import colors
$upload-header-background-color = $top-navigation-color
$upload-header-background-color-darktheme = $top-navigation-color-darktheme
$upload-border-color = #DDD
$cancel-button-color = tomato

#post-upload
    form
        width: 100%
        max-width: 40em
        margin: 0 auto
        text-align: left

        &.inactive input[type=submit],
        &.inactive .batch-defaults,
        &.inactive .upload-options,
        &.inactive .bulk-strip,
        &.uploading input[type=submit],
        &.uploading .batch-defaults,
        &.uploading .upload-options,
        &.uploading .bulk-strip,
        &:not(.uploading) .cancel
            display: none

    .dropper-container
        margin: 0 auto
        .file-dropper
            font-size: 150%
            padding: 2em
            small
                font-size: 60%

    .primary-bar
        display: flex
        align-items: center
        gap: 0.6em
        margin-top: 1em

        input[type=submit],
        .cancel
            margin: 0

        .progress
            margin-left: auto
            font-size: 0.95em
            opacity: 0.8

    .cancel
        background: $cancel-button-color
        border-color: $cancel-button-color
        &:focus
            border: 2px solid $text-color

    .segmented
        display: inline-flex
        border: 1px solid $upload-border-color
        border-radius: 4px
        overflow: hidden

        a
            padding: 0.15em 0.85em
            font-size: 0.95em
            text-decoration: none
            &:not(:last-child)
                border-right: 1px solid $upload-border-color
            &.active
                background: $main-color
                color: white

    .action
        padding: 0.15em 0.7em
        border: 1px solid $upload-border-color
        border-radius: 4px
        text-decoration: none
        &.danger
            color: $cancel-button-color
            border-color: $cancel-button-color

    .batch-defaults
        margin-top: 0.9em

        .field
            display: flex
            align-items: center
            gap: 0.6em
            margin-bottom: 0.45em

        .field-label
            flex: 0 0 7.5em
            font-size: 0.95em
            opacity: 0.75

        input[type=text]
            flex: 1 1 auto
            box-sizing: border-box

    .upload-options
        margin-top: 0.7em

        .upload-options-toggle
            font-size: 0.95em
            &:before
                content: '\25b8\00a0'

        &.open .upload-options-toggle:before
            content: '\25be\00a0'

        .upload-options-body
            display: none
            margin-top: 0.5em
            padding: 0.5em 0.7em
            border: 1px solid $upload-border-color
            border-radius: 4px

            >span
                display: inline-block
                margin: 0.15em 1.3em 0.15em 0

            input[type=number]
                width: 3.5em
                margin: 0 0.3em
                padding: 0.2em 0.3em

            .suffix
                margin-left: -0.1em

        &.open .upload-options-body
            display: block

    .bulk-strip
        margin-top: 0.9em
        padding: 0.5em 0.7em
        border: 1px solid $upload-border-color
        border-radius: 4px
        font-size: 0.95em

        .selection-bar
            display: flex
            align-items: center
            gap: 0.8em

            .selection-info
                opacity: 0.75

            .selection-links
                margin-left: auto
                display: flex
                gap: 0.9em

        .selection-actions
            display: none
            flex-wrap: wrap
            align-items: center
            gap: 0.5em 1.3em
            margin-top: 0.6em
            padding-top: 0.6em
            border-top: 1px solid $upload-border-color

            .group
                display: inline-flex
                align-items: center
                gap: 0.4em

            .group-label
                opacity: 0.7

            input[name=bulk-tags]
                width: 11em
                padding: 0.15em 0.35em

        &.has-selection .selection-actions
            display: flex

    .uploadable .tags
        margin: 0.4em 0
        input
            width: 100%
            box-sizing: border-box

    .uploadable-container
        &.selected .uploadable
            border-color: $main-color
            box-shadow: 0 0 0 1px $main-color

        &.dragging
            opacity: 0.5

        &.drop-target .uploadable
            border-top: 2px solid $main-color

        .drag-handle
            flex: 0 0 auto
            cursor: grab
            padding: 0 0.2em
            opacity: 0.55
            &:hover
                opacity: 1

        .file-info
            flex: 0 0 auto
            white-space: nowrap
            font-size: 0.85em
            opacity: 0.65

        .status
            flex: 0 0 auto
            white-space: nowrap
            font-size: 0.85em
            opacity: 0.85

    form>.messages
        margin-top: 1em

    .uploadables-container
        list-style-type: none
        margin: 0
        padding: 0

        .uploadable-container
            clear: both
            margin: 0 0 1.2em 0
            padding-left: 13em

            img
                width: 100%
                height: 100%
            
            video
                width: 100%
                height: 100%

            &>.thumbnail-wrapper
                float: left
                width: 12em
                height: 8em
                margin: 0 0 0 -13em
                .thumbnail
                    width: 100%
                    height: 100%

            .uploadable
                border: 1px solid $upload-border-color
                min-height: 8em
                box-sizing: border-box

                header
                    line-height: 1.5em
                    padding: 0.25em 1em
                    text-align: left
                    background: $upload-header-background-color
                    border-bottom: 1px solid $upload-border-color

                    nav
                        &:first-of-type
                            float: left
                            a
                                margin: 0 0.5em 0 0
                        &:last-of-type
                            float: right
                            a
                                margin: 0 0 0 0.5em

                        ul
                            list-style-type: none
                        ul, li
                            display: inline-block
                            margin: 0
                            padding: 0

                    // keeps the whole header on a single line: the flex box
                    // sits between the floated navs and never overlaps them
                    .file-line
                        display: flex
                        align-items: baseline
                        gap: 0.4em
                        overflow: hidden

                    span.filename
                        padding: 0 0.5em
                        flex: 1 1 auto
                        min-width: 0
                        overflow: hidden
                        white-space: nowrap
                        text-overflow: ellipsis

                .body
                    margin: 1em

                    .anonymous
                        margin: 0.3em 0

                    .safety
                        margin: 0.3em 0
                        label
                            display: inline-block
                            margin-right: 1em

                    .options div
                        display: inline-block
                        margin: 0 1em 0 0

                    .messages
                        margin-top: 1em
                        .message:last-child
                            margin-bottom: 0

                    .lookalikes
                        list-style-type: none
                        margin: 0
                        padding: 0

                        li
                            clear: both
                            margin: 1em 0 0 0
                            padding-left: 7em
                            font-size: 90%

                            .thumbnail-wrapper
                                float: left
                                width: 6em
                                height: 4em
                                margin: 0 0 0 -7em
                                .thumbnail
                                    width: 100%
                                    height: 100%

                        .description
                            margin-right: 0.5em
                            display: inline-block
                        .controls
                            float: right
                            display: inline-block


            &:first-child .move-up
                color: $inactive-link-color
            &:last-child .move-down
                color: $inactive-link-color
            .darktheme &:first-child .move-up
                color: $inactive-link-color-darktheme
            .darktheme &:last-child .move-down
                color: $inactive-link-color-darktheme

.darktheme #post-upload .uploadables-container .uploadable-container
    .uploadable header
        background: $upload-header-background-color-darktheme
    &:first-child .move-up
        color: $inactive-link-color-darktheme
    &:last-child .move-down
        color: $inactive-link-color-darktheme
