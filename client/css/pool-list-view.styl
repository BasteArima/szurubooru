@import colors

.pool-list
    .sort-bar
        margin: 0 0 1em 0
        font-size: 0.95em
        color: $inactive-link-color

    .pool-grid
        list-style: none
        margin: 0
        padding: 0
        display: grid
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr))
        gap: 1.2em

    .pool-card
        display: flex
        flex-direction: column
        min-width: 0

        .cover
            position: relative
            display: block
            width: 100%
            padding-top: 140%
            overflow: hidden
            border-radius: 5px
            background: rgba(127, 127, 127, 0.12)

            > .thumbnail,
            > .no-cover
                position: absolute
                top: 0
                left: 0
                width: 100%
                height: 100%

            .page-count
                position: absolute
                top: 6px
                left: 6px
                z-index: 1
                padding: 1px 7px
                border-radius: 10px
                background: rgba(0, 0, 0, 0.65)
                color: #fff
                font-size: 0.8em
                line-height: 1.5

        .title
            display: -webkit-box
            -webkit-line-clamp: 2
            -webkit-box-orient: vertical
            overflow: hidden
            margin-top: 0.45em
            font-weight: bold
            line-height: 1.25

        .category
            margin-top: 0.15em
            font-size: 0.85em
            opacity: 0.85

    .no-pools
        opacity: 0.7

.darktheme .pool-list
    .sort-bar
        color: $inactive-link-color-darktheme

.pool-list-header
    label
        display: none !important
    text-align: left
    form
        width: auto
    input[name=search-text]
        width: 25em
        @media (max-width: 1000px)
            width: 100%
    .append
        vertical-align: middle
        font-size: 0.95em
        color: $inactive-link-color

.darktheme .pool-list-header
    .append
        color: $inactive-link-color-darktheme
