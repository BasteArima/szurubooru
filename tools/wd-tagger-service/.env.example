# Copy to .env (or set these in your shell / run script) before starting.

# Shared secret. szurubooru sends it as the X-Auth-Token header. Leave empty
# ONLY on a trusted, firewalled LAN - an empty token disables auth.
WD_AUTH_TOKEN=change-me

# Where model.onnx + selected_tags.csv live (download_model.py fills this).
WD_MODEL_DIR=./model

# HuggingFace repo used by download_model.py.
WD_MODEL_REPO=SmilingWolf/wd-vit-large-tagger-v3

# Default thresholds when the request does not pass its own.
WD_GENERAL_THRESHOLD=0.35
WD_CHARACTER_THRESHOLD=0.75

# Bind address / port (0.0.0.0 = reachable from the LAN).
WD_HOST=0.0.0.0
WD_PORT=7860
